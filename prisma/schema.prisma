generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Product {
  id                 Int             @id @default(autoincrement())
  name               String
  category           String?
  classification     String?
  unit               String?         @default("قطعه")
  secondaryUnit      String?
  conversionFactor   Int             @default(1)
  barcode            String?         @unique
  openingQty         Float           @default(0)
  openingWeightedAvg Float           @default(0)
  secondaryPrice     Float?
  lastSellPrice      Float?
  lastPurchasePrice  Float?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  lots               InventoryLot[]
  invoiceItems       InvoiceItem[]
  quotationItems     QuotationItem[]
}

model InventoryLot {
  id           Int           @id @default(autoincrement())
  productId    Int
  batchNumber  String
  expiryDate   DateTime
  quantity     Float
  costPrice    Float
  sellingPrice Float
  createdAt    DateTime      @default(now())
  product      Product       @relation(fields: [productId], references: [id])
  invoiceItems InvoiceItem[]
}

model Person {
  id             Int         @id @default(autoincrement())
  name           String
  type           String
  phone          String?
  address        String?
  initialBalance Float       @default(0)
  currentBalance Float       @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  invoices       Invoice[]
  payments       Payment[]
  quotations     Quotation[]
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String?
  serialNumber  Int?
  type          String
  personId      Int?
  date          DateTime      @default(now())
  totalAmount   Float
  paidAmount    Float         @default(0)
  paymentStatus String
  paymentMethod String?
  discount      Float         @default(0)
  deliveryFee   Float         @default(0)
  netAmount     Float         @default(0)
  cogs          Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
  person        Person?       @relation(fields: [personId], references: [id])
  items         InvoiceItem[]
  logs          InvoiceLog[]
  payments      Payment[]
}

model InvoiceLog {
  id        Int      @id @default(autoincrement())
  invoiceId Int?
  action    String
  oldData   String
  newData   String?
  reason    String?
  createdAt DateTime @default(now())
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

model InvoiceItem {
  id        Int           @id @default(autoincrement())
  invoiceId Int
  productId Int
  lotId     Int?
  quantity  Float
  unitType  String        @default("PRIMARY")
  price     Float
  costPrice Float?
  discount  Float         @default(0)
  total     Float
  totalNet  Float         @default(0)
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lot       InventoryLot? @relation(fields: [lotId], references: [id])
  product   Product       @relation(fields: [productId], references: [id])
}

model Payment {
  id        Int       @id @default(autoincrement())
  personId  Int
  invoiceId Int?
  amount    Float
  type      String
  method    String?
  date      DateTime  @default(now())
  notes     String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id])
  person    Person    @relation(fields: [personId], references: [id])
}

model Expense {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  category      String
  description   String?
  amount        Float
  paymentMethod String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Quotation {
  id              Int             @id @default(autoincrement())
  quotationNumber String?         @unique
  personId        Int?
  date            DateTime        @default(now())
  expiryDate      DateTime?
  totalAmount     Float
  discount        Float           @default(0)
  deliveryFee     Float           @default(0)
  netAmount       Float           @default(0)
  status          String          @default("PENDING")
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  person          Person?         @relation(fields: [personId], references: [id])
  items           QuotationItem[]
}

model QuotationItem {
  id          Int       @id @default(autoincrement())
  quotationId Int
  productId   Int
  quantity    Float
  unitType    String    @default("PRIMARY")
  price       Float
  total       Float
  product     Product   @relation(fields: [productId], references: [id])
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Transfer {
  id          Int      @id @default(autoincrement())
  amount      Float
  fromMethod  String
  toMethod    String
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
